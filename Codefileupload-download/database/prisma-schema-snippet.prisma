model Uploads {
  id                Int               @id @default(autoincrement())
  namefile          String
  url               String?
  fileType          String?           // 'image', 'pdf', 'document'
  size              Int?
  token             String            @unique @default(uuid())
  createdAt         DateTime          @default(now())
  uploadedBy        Int?
   
}
